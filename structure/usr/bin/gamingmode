#!/bin/bash
# disable mouse mode
xinput set-prop "Nintendo Switch Combined Joy-Cons" "Generate Key Events" 0
xinput set-prop "Nintendo Switch Combined Joy-Cons" "Generate Mouse Events" 0
# disable mouse mode (Lite)
xinput set-prop "Nintendo Switch Lite Gamepad" "Generate Mouse Events" 0
xinput set-prop "Nintendo Switch Lite Gamepad" "Generate Key Events" 0
# hide mouse
xdotool mousemove 10000 10000
# thingamabongs
picom &
xbindkeys &
# Fix sleep and dock returning OC mode to handheld
/usr/share/nvpmodel_indicator/nvpmodel_helper.sh 5 0
# OC
pkexec nvpmodel -m 4

openbox &

# splash
feh --fullscreen --borderless --auto-zoom --hide-pointer --image-bg black /usr/share/splash/steam-splash.png &
# make screen not go turn off
xset s off
xset s noblank
xset s -dpms
# battery check loop so steam has a battery icon
while ! upower -e | grep -q 'battery_battery'; do
    sleep 1
done

# launch Big Picture
steam -bigpicture -no-cef-sandbox -cef-single-process
sleep 7
# make sure picom always running because it likes to crash
(
    while true; do
        # check for openbox, otherwise kill
        if pgrep -x "openbox" > /dev/null; then
            pgrep -x "picom" > /dev/null || picom &
        else
            pkill -x "picom" 2>/dev/null
        fi
        # if switching desktop or rebooting to hekate, exit
        if pgrep -x "switch-desktop" > /dev/null || pgrep -x "reboot-hekate" > /dev/null; then
            pkill -x "picom"
            exit 0
        fi
        sleep 0.5
    done
) &

# if steam closes, go to desktop
/usr/bin/switch-desktop
